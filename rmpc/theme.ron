#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    // configuración general del tema
    background_color: None,
    default_album_art_path: None,
    header_background_color: None,
    modal_background_color: None,
    modal_backdrop: false,
    format_tag_separator: " | ",
    multiple_tag_resolution_strategy: All,
    text_color: None,
    browser_column_widths: [20, 35, 45],
    scrollbar: None,
    song_table_album_separator: None,

    // colores del tema
    preview_label_style: (fg: "yellow"),
    preview_metadata_group_style: (fg: "yellow", modifiers: "Bold"),
    highlighted_item_style: (fg: "blue", modifiers: "Bold"),
    current_item_style: (fg: "black", bg: "blue"),
    borders_style: (fg: "blue"),
    highlight_border_style: (fg: "yellow"),

    symbols: (
        song: "",
        dir: "",
        playlist: "󰲹",
        marker: "",
        ellipsis: "..",
        song_style: None,
        dir_style: None,
        playlist_style: None,
    ),

    cava: (
        bar_width: 1,
        bar_spacing: 1,
        orientation: Bottom,
        bar_color: Single("blue"),
    ),

    tab_bar: (
        active_style: (fg: "black", bg: "blue"),
        inactive_style: (fg: "white"),
        separator: " | ",
    ),

    progress_bar: (
        symbols: ["", "█", "", "█", "" ],
        track_style: (fg: "black"),
        elapsed_style: (fg: "blue"),
        thumb_style: (fg: "blue", bg: "black"),
        use_track_when_empty: false,
    ),

    browser_song_format: [
        (
            kind: Property(Other("name")),
            default: (
                kind: Group([
                    (kind: Property(Artist)),
                    (kind: Text(" - ")),
                    (kind: Property(Title)),
                ]),
                default: (kind: Property(Filename))
            ),
        )
    ],

    level_styles: (
        info: (fg: "blue", bg: "black"),
        warn: (fg: "yellow", bg: "black"),
        error: (fg: "red", bg: "black"),
        debug: (fg: "light_green", bg: "black"),
        trace: (fg: "magenta", bg: "black"),
    ),

    // configuración del menú de cola
    song_table_format: [
        (
            prop: (kind: Property(Artist), default: (kind: Text("Desconocido"))),
            label_prop: (kind: Text("Artista")),
            width: "20%",
        ),
        (
            prop: (kind: Property(Title), default: (kind: Text("Desconocido"))),
            label_prop: (kind: Text("Título")),
            width: "50%",
        ),
        (
            prop: (kind: Property(Album), default: (kind: Text("Desconocido"))),
            label_prop: (kind: Text("Álbum")),
            width: "30%",
        ),
        (
            prop: (kind: Property(Duration), default: (kind: Text("0:00"))),
            label_prop: (kind: Text("Duración")),
            width: "4",
            alignment: Left,
        ),
    ],

    // configuración de posición de componentes
    components: {
        "state": Pane(Property(
            content: [
                (kind: Text(" ")),
                (kind: Text("["), style: (fg: "yellow")),
                (kind: Property(Status(StateV2())), style: (fg: "yellow")),
                (kind: Text("]"), style: (fg: "yellow")),
            ], align: Left,
        )),

       "title": Pane(Property(
            content: [
                (kind: Property(Song(Title)), style: (fg: "blue", modifiers: "Bold"),
                    default: (kind: Property(Song(Filename)), style: (fg: "blue", modifiers: "Bold")))
            ], align: Center, scroll_speed: 1
        )),

        "volume": Split(
            direction: Horizontal,
            panes: [
                (size: "1", pane: Pane(Empty())),
                (size: "100%", pane: Pane(Volume(kind: Slider(symbols: (filled: "─", thumb: "●", track: "─"))))),
                (size: "3", pane: Pane(Property(content: [(kind: Property(Status(Volume)), style: (fg: "blue"))], align: Right))),
                (size: "1", pane: Pane(Property(content: [(kind: Text("%"), style: (fg: "blue"))]))),
                (size: "1", pane: Pane(Empty())),
            ]
        ),

        "elapsed_and_bitrate": Pane(Property(
            content: [
                (kind: Text(" ")),
                (kind: Property(Status(Elapsed))),
                (kind: Text(" / ")),
                (kind: Property(Status(Duration))),
                (kind: Group([
                    (kind: Text(" (")),
                    (kind: Property(Status(Bitrate))),
                    (kind: Text(" kbps)")),
                ])),
            ], align: Left, scroll_speed: 1
        )),

        "artist_title": Pane(Property(
            content: [
                (kind: Property(Song(Artist)), style: (fg: "yellow"), default: (kind: Text("Artista desconocido"), style: (fg: "yellow"))),
                (kind: Text(" - ")),
                (kind: Property(Song(Title)), style: (fg: "yellow"), default: (kind: Text("Título desconocido"),  style: (fg: "yellow"))),
            ], align: Center, scroll_speed: 1
        )),

        "states": Pane(Property(
            content: [
                (kind: Property(Status(RepeatV2(
                    on_label: "󰑖 ", off_label: "󰑖 ",
                    on_style: (fg: "yellow"), off_style: (fg: "blue"),
                )))),
                (kind: Text(" ")),
                (kind: Property(Status(RandomV2(
                    on_label: "󰒝 ", off_label: "󰒝 ",
                    on_style: (fg: "yellow"), off_style: (fg: "blue"),
                )))),
                (kind: Text(" ")),
                (kind: Property(Status(SingleV2(
                    on_label: "󰑘 ", off_label: "󰑘 ", oneshot_label: "󰑘 ",
                    on_style: (fg: "yellow"), off_style: (fg: "blue"), oneshot_style: (fg: "red"),
                )))),
                (kind: Text(" ")),
                (kind: Property(Status(ConsumeV2(
                    on_label: "󰮯 ", off_label: "󰮯 ", oneshot_label: "󰮯 ",
                    on_style: (fg: "yellow"), off_style: (fg: "blue"), oneshot_style: (fg: "red"),
                )))),
            ], align: Right
        )),

        "top_row": Split(
            direction: Horizontal,
            panes: [
                (size: "25", pane: Component("state")),
                (size: "100%", borders: "LEFT | RIGHT", pane: Component("title")),
                (size: "25", pane: Component("volume")),
            ],
        ),
        "bottom_row": Split(
            direction: Horizontal,
            panes: [
                (size: "25", pane: Component("elapsed_and_bitrate")),
                (size: "100%", borders: "LEFT | RIGHT", pane: Component("artist_title")),
                (size: "25", pane: Component("states")),
            ],
        ),
        "header": Split(
            direction: Vertical,
            panes: [
                (size: "1", direction: Vertical, pane: Component("top_row")),
                (size: "1", direction: Vertical, pane: Component("bottom_row")),
            ]
        ),

        "progress_bar": Split(
            direction: Horizontal,
            panes: [
                (
                    pane: Pane(Property(content: [(kind: Property(Status(StateV2(
                        playing_label: "󰐊 ", paused_label: "󰏤 ", stopped_label: "󰓛 ",
                        playing_style: (fg: "blue"), paused_style: (fg: "green"), stopped_style: (fg: "yellow")
                    ))))], align: Left)),
                    size: "3",
                ),
                (size: "100%", pane: Pane(ProgressBar)),
                (
                    size: "13",
                    pane: Pane(Property(
                        content: [
                            (kind: Property(Status(Elapsed))),
                            (kind: Text(" / ")),
                            (kind: Property(Status(Duration))),
                        ], align: Right,
                    )),
                ),
            ]
        ),
    },

    // configuración general del diseño
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                borders: "ALL",
                border_symbols: Inherited(parent: Rounded),
                pane: Component("header"),
            ),
            (
                size: "3",
                borders: "ALL",
                border_symbols: Inherited(parent: Rounded),
                pane: Pane(Tabs),
            ),
            (
                size: "100%",
                borders: "ALL",
                border_symbols: Inherited(parent: Rounded),
                pane: Pane(TabContent),
            ),
            (
                size: "3",
                borders: "ALL",
                border_symbols: Inherited(parent: Rounded),
                pane: Component("progress_bar"),
            ),
        ]
    ),
)
